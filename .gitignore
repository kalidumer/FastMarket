# ====================================================================
# FastMarket Monorepo Master .gitignore Configuration
# ====================================================================

# --------------------------------------------------------------------
# 🐍 Python / FastAPI / uv Dependencies & Caches
# --------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual Environments (Standard and uv layouts)
.venv/
venv/
ENV/
env/
.uv/

# --------------------------------------------------------------------
# ⚛️ JavaScript / Node / React (Frontend & Dashboard)
# --------------------------------------------------------------------
node_modules/
/dashboard/node_modules/
/frontend-service/node_modules/

# Production build artifacts
dist/
/dashboard/dist/
/frontend-service/dist/

# Frontend Caches (Vite, Next, etc.)
.eslintcache
.vite/
.turbo/

# Log files
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# --------------------------------------------------------------------
# 🔐 Security, Private Keys & Environment Variables
# --------------------------------------------------------------------
# NEVER commit your actual API tokens or Supabase connection strings!
.env
.env.local
.env.*.local
*.env
backend-service/.env

# --------------------------------------------------------------------
# 🖥️ Operating System Specific Clutter
# --------------------------------------------------------------------
# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# IDEs and Text Editors
.idea/
.project
.classpath
.cproject
.settings/
*.sublime-project
*.sublime-workspace

# VS Code internal configurations (Keep shared workspaces clean)
.vscode/
!.vscode/extensions.json
.history/
*.log