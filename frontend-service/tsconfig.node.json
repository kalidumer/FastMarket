{
  "compilerOptions": {
    "composite": true,
    "tsBuildInfoFile": "./node_modules/.typescript/tsconfig.node.tsbuildinfo",
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    
    /* Paths defined directly relative to the compiler root without a conflicting baseUrl */
    "paths": {
      "@/*": ["./src/*"]
    },
    
    "strict": true,
    "allowSyntheticDefaultImports": true
  },
  "include": ["vite.config.ts"]
}